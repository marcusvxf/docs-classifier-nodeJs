# ── Server ────────────────────────────────────────────────────
PORT=3000
LOG_LEVEL=info

# ── PostgreSQL ────────────────────────────────────────────────
DATABASE_URL=postgres://postgres:postgres@localhost:5432/docs_classifier

# ── Ollama ────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_API_KEY=
OLLAMA_TIMEOUT_MS=30000

# ── Chat / Classify ──────────────────────────────────────────
OLLAMA_DEFAULT_MODEL=llama3
